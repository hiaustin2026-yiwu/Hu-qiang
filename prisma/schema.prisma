generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Merchant {
  id          String    @id @default(cuid())
  name        String
  market      String
  district    String
  booth       String
  contact     String
  phone       String
  wechat      String
  email       String
  country     String
  description String
  coverImage  String
  verified    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  products    Product[]
  inquiries   Inquiry[]
}

model Product {
  id            String         @id @default(cuid())
  merchantId    String
  sku           String         @unique
  nameCN        String
  nameEN        String
  category      String
  material      String
  size          String
  color         String
  moq           String
  price         String
  currency      String         @default("USD")
  packageInfo   String         @map("package")
  leadTime      String
  descriptionCN String
  descriptionEN String
  status        String         @default("active")
  createdAt     DateTime       @default(now())
  merchant      Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  images        ProductImage[]
  inquiries     Inquiry[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  imageUrl  String
  sort      Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id             String   @id @default(cuid())
  productId      String?
  merchantId     String?
  buyerName      String
  buyerEmail     String
  buyerWhatsapp  String
  country        String
  quantity       String
  budget         String
  message        String
  status         String   @default("new")
  createdAt      DateTime @default(now())
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  merchant       Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)
}

model AIMatchRequest {
  id               String   @id @default(cuid())
  productKeyword   String
  quantity         String
  country          String
  budget           String
  category         String
  message          String
  resultProductIds String
  createdAt        DateTime @default(now())
}

model CollectionTask {
  id                  String    @id @default(cuid())
  merchantName        String
  marketLocation      String
  boothNumber         String
  contactName         String
  phone               String
  wechat              String
  status              String    @default("todo")
  visitedAt           DateTime?
  photoStatus         String
  skuCount            Int       @default(0)
  authorizationStatus String
  notes               String
  createdAt           DateTime  @default(now())
}
